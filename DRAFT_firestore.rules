rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'mrachmanfm@gmail.com'
      );
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validations ---
    function isValidBooking(data) {
      return data.keys().hasAll(['userId', 'nama', 'email', 'wa', 'destinasi', 'durasi', 'jadwal', 'peserta', 'createdAt', 'status']) &&
             data.userId == request.auth.uid &&
             data.nama is string && data.nama.size() <= 100 &&
             data.wa is string && data.wa.size() <= 20 &&
             data.status in ['pending', 'confirmed', 'cancelled'] &&
             data.createdAt == request.time;
    }

    // --- Rules ---
    
    match /bookings/{bookingId} {
      allow create: if isEmailVerified() && isValidId(bookingId) && isValidBooking(incoming());
      allow read: if isEmailVerified() && (existing().userId == request.auth.uid || isAdmin());
      allow update: if isEmailVerified() && isAdmin(); // Only admins can update status etc.
      allow delete: if isAdmin();
    }

    // Website Config & Data Collections
    match /website/data {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /destinations/data {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /leaders/data {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /gallery/data {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /openTrips/data {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if false; // System managed or manually added in console
    }
  }
}
