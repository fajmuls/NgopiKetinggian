rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isValidBooking(data) {
      return data.keys().hasAll(['userId', 'nama', 'email', 'wa', 'destinasi', 'durasi', 'jadwal', 'peserta', 'createdAt', 'status'])
        && data.size() >= 10 && data.size() <= 12
        && data.userId == request.auth.uid
        && data.nama is string && data.nama.size() <= 200
        && data.email is string && data.email.size() <= 200
        && data.wa is string && data.wa.size() <= 100
        && data.destinasi is string && data.destinasi.size() <= 200
        && data.durasi is string && data.durasi.size() <= 100
        && data.jadwal is string && data.jadwal.size() <= 200
        && data.peserta is string && data.peserta.size() <= 50
        && data.status is string && data.status.size() <= 50
        && data.createdAt == request.time
        && (!('opsionalText' in data) || (data.opsionalText is string && data.opsionalText.size() <= 1000))
        && (!('deskripsi' in data) || (data.deskripsi is string && data.deskripsi.size() <= 2000));
    }

    match /bookings/{bookingId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid && isValidId(bookingId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() 
                    && isValidId(bookingId) 
                    && request.auth.token.email_verified == true
                    && isValidBooking(incoming());
      
      allow update: if isSignedIn()
                    && isValidId(bookingId)
                    && existing().userId == request.auth.uid
                    && request.auth.token.email_verified == true
                    && isValidBooking(incoming())
                    && incoming().diff(existing()).affectedKeys().hasOnly(['status'])
                    && incoming().userId == existing().userId
                    && incoming().createdAt == existing().createdAt;
                    
      allow delete: if false; // Only admin can delete bookings
    }
  }
}
